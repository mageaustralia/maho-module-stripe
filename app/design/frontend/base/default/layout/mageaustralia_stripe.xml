<?xml version="1.0"?>
<layout>
    <checkout_onepage_index>
        <reference name="head">
            <action method="addItem"><type>external_js</type><name>https://js.stripe.com/v3/</name></action>
        </reference>
    </checkout_onepage_index>
    <stripe_payment_payment_redirect>
        <reference name="root">
            <action method="setTemplate"><template>page/1column.phtml</template></action>
        </reference>
        <reference name="content">
            <block type="stripe/payment_redirect" name="stripe.redirect" template="mageaustralia/stripe/payment/redirect.phtml"/>
        </reference>
    </stripe_payment_payment_redirect>
</layout>
