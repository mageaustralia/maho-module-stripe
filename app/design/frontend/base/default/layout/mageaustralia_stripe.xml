<?xml version="1.0"?>
<layout>
    <checkout_onepage_index>
        <reference name="head">
            <block type="core/text" name="stripe_js">
                <action method="setText"><text><![CDATA[<script src="https://js.stripe.com/v3/"></script>]]></text></action>
            </block>
            <action method="addItem"><type>skin_js</type><name>js/stripe-elements-checkout.js</name></action>
        </reference>
    </checkout_onepage_index>
    <stripe_payment_payment_redirect>
        <reference name="root">
            <action method="setTemplate"><template>page/1column.phtml</template></action>
        </reference>
        <reference name="content">
            <block type="stripe/payment_redirect" name="stripe.redirect" template="mageaustralia/stripe/payment/redirect.phtml"/>
        </reference>
    </stripe_payment_payment_redirect>
</layout>
