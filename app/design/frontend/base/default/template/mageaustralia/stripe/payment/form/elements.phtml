<?php /** @var MageAustralia_Stripe_Block_Payment_Form_Elements $this */ ?>
<?php $code = $this->getMethodCode(); ?>
<ul class="form-list" id="payment_form_<?php echo $this->escapeHtml($code) ?>" style="display:none">
    <li>
        <div id="stripe-card-element"></div>
        <div id="stripe-card-errors" role="alert" style="color: #fa755a; margin-top: 8px;"></div>
        <input type="hidden" name="payment[stripe_payment_method_id]" id="stripe-payment-method-id" value="" />
    </li>
</ul>
<script>
(function() {
    'use strict';
    var publishableKey = <?php echo json_encode($this->getPublishableKey()); ?>;
    if (!publishableKey) return;

    var stripe = Stripe(publishableKey);
    var elements = stripe.elements();
    var cardElement = elements.create('card', {
        style: {
            base: {
                fontSize: '16px',
                color: '#32325d',
                fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif',
                '::placeholder': { color: '#aab7c4' }
            },
            invalid: { color: '#fa755a', iconColor: '#fa755a' }
        }
    });

    // Mount when payment form becomes visible
    var observer = new MutationObserver(function() {
        var container = document.getElementById('stripe-card-element');
        if (container && container.offsetParent !== null && !container.hasChildNodes()) {
            cardElement.mount('#stripe-card-element');
        }
    });
    observer.observe(document.body, { childList: true, subtree: true, attributes: true });

    // Also try mounting immediately
    var container = document.getElementById('stripe-card-element');
    if (container && container.offsetParent !== null) {
        cardElement.mount('#stripe-card-element');
    }

    cardElement.on('change', function(event) {
        var errorEl = document.getElementById('stripe-card-errors');
        errorEl.textContent = event.error ? event.error.message : '';
    });

    // Hook into Maho's payment form submission
    if (typeof payment !== 'undefined') {
        payment.addAfterInitFunction('stripe_card', function() {
            // Nothing extra needed on init
        });
    }
})();
</script>
